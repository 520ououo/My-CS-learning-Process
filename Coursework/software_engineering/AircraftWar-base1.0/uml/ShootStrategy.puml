@startuml
' Strategy pattern for shooting trajectories

title Strategy Pattern

interface ShootStrategy {
  + shoot(aircraft: AbstractAircraft, shootNum: int, power: int, direction: int): List<BaseBullet>
}

class StraightShootStrategy
class ScatterShootStrategy
class CircularShootStrategy
class EmptyShootStrategy

ShootStrategy <|.. StraightShootStrategy
ShootStrategy <|.. ScatterShootStrategy
ShootStrategy <|.. CircularShootStrategy
ShootStrategy <|.. EmptyShootStrategy

abstract class AbstractAircraft {
  # shootNum: int
  # power: int
  # direction: int
  - shootStrategy: ShootStrategy
  + shoot(): List<BaseBullet>
  + setShootStrategy(strategy: ShootStrategy): void
}

AbstractAircraft --> ShootStrategy : uses

class HeroAircraft
class EliteEnemy
class ElitePlusEnemy
class EliteProEnemy
class BossEnemy
class FireProp
class SuperFireProp

AbstractAircraft <|-- HeroAircraft
AbstractAircraft <|-- EliteEnemy
AbstractAircraft <|-- ElitePlusEnemy
AbstractAircraft <|-- EliteProEnemy
AbstractAircraft <|-- BossEnemy

HeroAircraft ..> StraightShootStrategy
EliteEnemy ..> StraightShootStrategy
ElitePlusEnemy ..> StraightShootStrategy
EliteProEnemy ..> ScatterShootStrategy
BossEnemy ..> CircularShootStrategy

FireProp ..> HeroAircraft : set ScatterShootStrategy
SuperFireProp ..> HeroAircraft : set CircularShootStrategy

@enduml
