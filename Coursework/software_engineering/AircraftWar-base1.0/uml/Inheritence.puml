@startuml
'https://plantuml.com/class-diagram

' --- 核心抽象层 ---

abstract class 抽象飞行物 {
    # 横坐标:int
    # 纵坐标:int
    # 水平速度:int
    # 垂直速度:int
    # 图像:BufferedImage
    # 位置宽度:int
    # 位置高度:int
    # 是否有效:boolean

    + 抽象飞行物(int 横坐标, int 纵坐标, int 水平速度, int 垂直速度)
    + 向前移动():void
    + 碰撞检测(抽象飞行物 目标):boolean
    + 设置坐标(double 横坐标, double 纵坐标):void
    + 获取横坐标():int
    + 获取纵坐标():int
    + 获取垂直速度():int
    + 获取图像():BufferedImage
    + 获取位置宽度():int
    + 获取位置高度():int
    + 是否消失():boolean
    + 消失():void
}

abstract class 抽象航空器 {
    # 最大血量:int
    # 当前血量:int
    + 抽象航空器(int 横坐标, int 纵坐标, int 水平速度, int 垂直速度, int 血量)
    + 减少血量(int 减少值):void
    + 获取血量():int
    + {abstract} 发射子弹():List<基础子弹>
}

' --- 英雄机 (单例模式) ---

class 英雄机 {
    - {static} 唯一实例:英雄机
    - 射击数量:int
    - 射击速度:int
    - 火力值:int
    - 方向:int
    - 英雄机(int 横坐标, int 纵坐标, int 水平速度, int 垂直速度, int 血量)
    + {static} 获取实例():英雄机
    + 向前移动():void
    + 发射子弹():List<基础子弹>
}

' --- 敌机抽象层 ---

abstract class 抽象敌机 {
    + 抽象敌机(int 横坐标, int 纵坐标, int 水平速度, int 垂直速度, int 血量)
    + {abstract} 向前移动():void
    + {abstract} 发射子弹():List<基础子弹>
}

' --- 敌机具体类 ---

class 普通敌机 {
    + 普通敌机(int 横坐标, int 纵坐标, int 水平速度, int 垂直速度, int 血量)
    + 向前移动():void
    + 发射子弹():List<基础子弹>
}

class 精英敌机 {
    + 精英敌机(int 横坐标, int 纵坐标, int 水平速度, int 垂直速度, int 血量)
    + 向前移动():void
    + 发射子弹():List<基础子弹>
}
note right:血量加厚，发射子弹

class 精锐敌机 {
    + 精锐敌机(int 横坐标, int 纵坐标, int 水平速度, int 垂直速度, int 血量)
    + 向前移动():void
    + 发射子弹():List<基础子弹>
}
note right:发射子弹，左右移动

class 王牌敌机 {
    + 王牌敌机(int 横坐标, int 纵坐标, int 水平速度, int 垂直速度, int 血量)
    + 向前移动():void
    + 发射子弹():List<快速子弹>
}
note right:血量加厚，子弹变快，左右移动

class Boss敌机 {
    + Boss敌机(int 横坐标, int 纵坐标, int 水平速度, int 垂直速度, int 血量)
    + 向前移动():void
    + 发射子弹():List<反弹子弹>
}
note right:血量加厚plus，左右移动，发射反弹子弹
' --- 子弹类层级 ---

abstract class 基础子弹 {
    - 杀伤力:int
    + 基础子弹(int 横坐标, int 纵坐标, int 水平速度, int 垂直速度, int 杀伤力)
    + 向前移动():void
    + 获取杀伤力():int
}

class 英雄子弹 {
    + 英雄子弹(int 横坐标, int 纵坐标, int 水平速度, int 垂直速度, int 杀伤力)
}

abstract class 抽象敌机子弹 {
    + 抽象敌机子弹(int 横坐标, int 纵坐标, int 水平速度, int 垂直速度, int 杀伤力)
}

class 普通敌机子弹 {
    + 普通敌机子弹(int 横坐标, int 纵坐标, int 水平速度, int 垂直速度, int 杀伤力)
}

class 快速敌机子弹 {
    + 快速敌机子弹(int 横坐标, int 纵坐标, int 水平速度, int 垂直速度, int 杀伤力)
}

class 反弹敌机子弹 {
    + 反弹敌机子弹(int 横坐标, int 纵坐标, int 水平速度, int 垂直速度, int 杀伤力)
}

' --- 道具类 ---

abstract class 抽象道具 {
    + 抽象道具(int 横坐标, int 纵坐标, int 水平速度, int 垂直速度)
    + {abstract} 生效(英雄机 英雄):void
}

class 加血道具 {
    + 生效(英雄机 英雄):void
}

class 火力道具 {
    + 生效(英雄机 英雄):void
}

class 超级火力道具 {
    + 生效(英雄机 英雄):void
}

class 炸弹道具 {
    + 生效(英雄机 英雄):void
}

class 冰冻道具 {
    + 生效(英雄机 英雄):void
}

' --- 关系定义 ---

抽象飞行物 <|-- 抽象航空器
抽象飞行物 <|-- 基础子弹
抽象飞行物 <|-- 抽象道具

抽象航空器 <|-- 英雄机
抽象航空器 <|-- 抽象敌机

抽象敌机 <|-- 普通敌机
抽象敌机 <|-- 精英敌机
抽象敌机 <|-- 精锐敌机
抽象敌机 <|-- 王牌敌机
抽象敌机 <|-- Boss敌机

基础子弹 <|-- 英雄子弹
基础子弹 <|-- 抽象敌机子弹
抽象敌机子弹 <|-- 普通敌机子弹
抽象敌机子弹 <|-- 快速敌机子弹
抽象敌机子弹 <|-- 反弹敌机子弹

抽象道具 <|-- 加血道具
抽象道具 <|-- 火力道具
抽象道具 <|-- 超级火力道具
抽象道具 <|-- 炸弹道具
抽象道具 <|-- 冰冻道具

@enduml